# Örnek ortam değişkenleri
# Kullanım: Bu dosyayı kopyalayıp ".env" adıyla kaydedin ve kendi değerlerinizi girin.
# --- MySQL (Docker Compose veya yerel) ---
MYSQL_ROOT_PASSWORD=1234
MYSQL_DATABASE=inventory_db
# Spring Boot veri kaynağı (manuel çalıştırmada application.yml içindeki ${...} ile eşleşir)
DB_PASSWORD=1234
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/inventory_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=1234
# --- JWT 
JWT_SECRET_KEY=
